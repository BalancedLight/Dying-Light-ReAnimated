{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/dl-reanimated/dlrmap.schema.v1.json",
  "title": "DL ReAnimated Humanoid Mapping Profile v1",
  "type": "object",
  "required": [
    "format",
    "schema_version",
    "profile_id",
    "name",
    "source_skeleton_hash",
    "role_to_bone"
  ],
  "properties": {
    "format": {"const": "dl-reanimated-retarget-profile"},
    "schema_version": {"const": 1},
    "profile_id": {"type": "string", "format": "uuid"},
    "name": {"type": "string"},
    "source_skeleton_hash": {"type": "string"},
    "role_to_bone": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "confidence_by_role": {
      "type": "object",
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "method_by_role": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "ignored_bones": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "array", "items": {"type": "string"}},
    "extensions": {"type": "object"}
  },
  "additionalProperties": true
}
